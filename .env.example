# ─────────────── База данных ───────────────
# Соответствует docker-compose.yml (порт 5434).
DATABASE_URL="postgresql://chessduel:chessduel@localhost:5434/chessduel?schema=public"

# ─────────────── NextAuth / Auth.js ───────────────
# Сгенерировать секрет:  npx auth secret   (или openssl rand -base64 32)
AUTH_SECRET="замените-на-случайную-строку-минимум-32-символа"

# Базовый URL приложения (для колбэков Auth.js)
NEXTAUTH_URL="http://localhost:3000"

# ─────────────── Приложение ───────────────
PORT=3000

# ─────────────── (Опционально) вход через Google ───────────────
# Заполните, если хотите включить Google-провайдер в src/lib/auth.ts.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
